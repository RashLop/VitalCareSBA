@page
@model FrontendVitalCare.Pages.Auth.OlvidoContrasenaModel

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Olvidé mi contraseña - VitalCare</title>
    <link href="~/css/auth-recovery.css" rel="stylesheet" />
</head>
<body>
    <div class="recovery-container">
        <div class="recovery-card">
            <div class="recovery-header">
                <h1>¿Olvidaste tu contraseña?</h1>
                <p>Te enviaremos un enlace para recuperarla</p>
            </div>

            <div class="recovery-body">
                @if (!string.IsNullOrWhiteSpace(Model.Mensaje))
                {
                    <div class="alert alert-@(Model.EsError ? "danger" : "success") alert-dismissible fade show">
                        @Model.Mensaje
                        <button type="button" class="btn-close" onclick="this.parentElement.style.display='none';" aria-label="Cerrar"></button>
                    </div>
                }

                @if (Model.MostrarFormulario)
                {
                    <form method="post">
                        <div class="form-group">
                            <label for="email">Correo Electrónico</label>
                            <input type="email"
                                   id="email"
                                   name="email"
                                   class="form-control"
                                   asp-for="Email"
                                   placeholder="Ingresa tu correo electrónico"
                                   required />
                        </div>

                        <button type="submit" class="btn btn-primary">
                            Enviar Enlace de Recuperación
                        </button>
                    </form>

                    <div class="recovery-footer">
                        <p>¿Ya tienes cuenta? <a href="/Auth/Login">Inicia sesión aquí</a></p>
                    </div>
                }
                else if (!Model.EsError)
                {
                    <div class="success-message">
                        <div class="alert alert-success">
                            <p>¡Correo enviado!</p>
                            <p>Hemos enviado un enlace de recuperación a tu correo electrónico.</p>
                            <p>El enlace expirará en 60 minutos.</p>
                        </div>

                        <div class="recovery-footer">
                            <p><a href="/Auth/Login">Volver al Login</a></p>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</body>
</html>