@page
@model FrontendVitalCare.Pages.Auth.RecuperarContrasenaModel

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Recuperar contraseña - VitalCare</title>
    <link href="~/css/auth-recovery.css" rel="stylesheet" />
</head>
<body>
    <div class="recovery-container">
        <div class="recovery-card">
            <div class="recovery-header">
                <h1>Cambiar Contraseña</h1>
                <p>Ingresa tu nueva contraseña</p>
            </div>

            <div class="recovery-body">
                @if (!string.IsNullOrWhiteSpace(Model.Mensaje))
                {
                    <div class="alert alert-@(Model.EsError ? "danger" : "success") alert-dismissible fade show">
                        @Model.Mensaje
                        <button type="button" class="btn-close" onclick="this.parentElement.style.display='none';" aria-label="Cerrar"></button>
                    </div>
                }

                @if (Model.MostrarFormulario)
                {
                    <form method="post">
                        <input type="hidden" name="token" value="@Model.Token" />

                        <div class="form-group">
                            <label for="nuevaPassword">Nueva Contraseña</label>
                            <div class="password-input-wrapper">
                                <input 
                                    type="password" 
                                    id="nuevaPassword" 
                                    name="nuevaPassword" 
                                    class="form-control" 
                                    asp-for="NuevaPassword"
                                    placeholder="Ingresa tu nueva contraseña"
                                    required />
                                <button type="button" class="toggle-password" onclick="togglePasswordVisibility('nuevaPassword', this)" aria-label="Mostrar contraseña" aria-pressed="false" title="Mostrar contraseña">
                                    <svg class="icon-eye icon-show" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                        <path d="M2 12s3.5-7 10-7 10 7 10 7-3.5 7-10 7-10-7-10-7Z"></path>
                                        <circle cx="12" cy="12" r="3"></circle>
                                    </svg>
                                    <svg class="icon-eye icon-hide" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                        <path d="M3 3l18 18"></path>
                                        <path d="M10.58 10.58A2 2 0 0 0 12 14a2 2 0 0 0 1.42-.58"></path>
                                        <path d="M9.88 5.09A9.77 9.77 0 0 1 12 5c6.5 0 10 7 10 7a13.16 13.16 0 0 1-2.17 2.94"></path>
                                        <path d="M6.61 6.61A13.53 13.53 0 0 0 2 12s3.5 7 10 7a9.77 9.77 0 0 0 2.12-.23"></path>
                                    </svg>
                                </button>
                            </div>
                        </div>

                        <div class="form-group">
                            <label for="confirmarPassword">Confirmar Contraseña</label>
                            <div class="password-input-wrapper">
                                <input 
                                    type="password" 
                                    id="confirmarPassword" 
                                    name="confirmarPassword" 
                                    class="form-control" 
                                    asp-for="ConfirmarPassword"
                                    placeholder="Confirma tu nueva contraseña"
                                    required />
                                <button type="button" class="toggle-password" onclick="togglePasswordVisibility('confirmarPassword', this)" aria-label="Mostrar contraseña" aria-pressed="false" title="Mostrar contraseña">
                                    <svg class="icon-eye icon-show" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                        <path d="M2 12s3.5-7 10-7 10 7 10 7-3.5 7-10 7-10-7-10-7Z"></path>
                                        <circle cx="12" cy="12" r="3"></circle>
                                    </svg>
                                    <svg class="icon-eye icon-hide" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                        <path d="M3 3l18 18"></path>
                                        <path d="M10.58 10.58A2 2 0 0 0 12 14a2 2 0 0 0 1.42-.58"></path>
                                        <path d="M9.88 5.09A9.77 9.77 0 0 1 12 5c6.5 0 10 7 10 7a13.16 13.16 0 0 1-2.17 2.94"></path>
                                        <path d="M6.61 6.61A13.53 13.53 0 0 0 2 12s3.5 7 10 7a9.77 9.77 0 0 0 2.12-.23"></path>
                                    </svg>
                                </button>
                            </div>
                        </div>

                        <div class="requisitos">
                            <p>Requisitos de contraseña:</p>
                            <ul id="requisitos-list">
                                <li id="req-length" class="req-item">
                                    <span class="req-icon">[ ]</span> Al menos 8 caracteres
                                </li>
                                <li id="req-upper" class="req-item">
                                    <span class="req-icon">[ ]</span> Contener una letra MAYUSCULA
                                </li>
                                <li id="req-lower" class="req-item">
                                    <span class="req-icon">[ ]</span> Contener una letra minuscula
                                </li>
                                <li id="req-number" class="req-item">
                                    <span class="req-icon">[ ]</span> Contener al menos un numero (0-9)
                                </li>
                            </ul>
                        </div>

                        <button type="submit" class="btn btn-primary" id="submitBtn" disabled>
                            Cambiar Contraseña
                        </button>
                    </form>

                    <div class="recovery-footer">
                        <p>¿Recordaste tu contraseña? <a href="/Auth/Login">Vuelve al login</a></p>
                    </div>
                }
                else if (!Model.EsError)
                {
                    <div class="success-message">
                        <div class="alert alert-success">
                            <p>¡Éxito!</p>
                            <p>Tu contraseña ha sido actualizada correctamente.</p>
                            <p>Ahora puedes iniciar sesion con tu nueva contraseña.</p>
                        </div>

                        <div class="recovery-footer">
                            <p><a href="/Auth/Login">Ir al Login</a></p>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>

    <script>
        function togglePasswordVisibility(inputId, button) {
            const input = document.getElementById(inputId);
            const showingPassword = input.type === 'text';
            input.type = showingPassword ? 'password' : 'text';
            button.classList.toggle('active', !showingPassword);
            button.setAttribute('aria-pressed', (!showingPassword).toString());
            button.setAttribute('aria-label', showingPassword ? 'Mostrar contraseña' : 'Ocultar contraseña');
            button.setAttribute('title', showingPassword ? 'Mostrar contraseña' : 'Ocultar contraseña');
        }

        function validatePassword() {
            const password = document.getElementById('nuevaPassword').value;
            const requirements = {
                length: password.length >= 8,
                upper: /[A-Z]/.test(password),
                lower: /[a-z]/.test(password),
                number: /[0-9]/.test(password)
            };

            updateRequirement('req-length', requirements.length);
            updateRequirement('req-upper', requirements.upper);
            updateRequirement('req-lower', requirements.lower);
            updateRequirement('req-number', requirements.number);

            const submitBtn = document.getElementById('submitBtn');
            const allMet = Object.values(requirements).every(val => val === true);
            submitBtn.disabled = !allMet;
        }

        function updateRequirement(elementId, isComplete) {
            const element = document.getElementById(elementId);
            if (isComplete) {
                element.classList.add('completed');
                element.querySelector('.req-icon').textContent = '[X]';
            } else {
                element.classList.remove('completed');
                element.querySelector('.req-icon').textContent = '[ ]';
            }
        }

        document.getElementById('nuevaPassword').addEventListener('input', validatePassword);
        document.getElementById('nuevaPassword').addEventListener('keyup', validatePassword);
        validatePassword();
    </script>
</body>
</html>
