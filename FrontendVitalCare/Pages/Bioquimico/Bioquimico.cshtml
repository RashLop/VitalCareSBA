@page
@model FrontendVitalCare.Pages.Bioquimico.BioquimicoModel
@{
    ViewData["Title"] = "Bioquímicos";
}

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-success">Bioquímicos Registrados</h2>

        <a asp-page="BioquimicoCreate" class="btn-main">
            + Nuevo Bioquímico
        </a>
    </div>

    <form method="get" class="mb-4">
        <div class="card-module p-3">
            <div class="input-group">
                <input type="text"
                       name="filtro"
                       class="form-control"
                       placeholder="Buscar por nombres, apellidos, CI, email o username..."
                       value="@Model.Estado.FiltroActual" />

                <button type="submit" class="btn btn-success btn-fixed">
                    Buscar
                </button>

                <a asp-page="Bioquimico" class="btn btn-secondary btn-fixed">
                    Limpiar
                </a>
            </div>
        </div>
    </form>

    @if (!string.IsNullOrEmpty(Model.Estado.Mensaje))
    {
        <div class="alert alert-success shadow-sm">@Model.Estado.Mensaje</div>
    }

    @if (!string.IsNullOrEmpty(Model.Estado.MensajeError))
    {
        <div class="alert alert-danger shadow-sm">@Model.Estado.MensajeError</div>
    }

    <div class="card-module">
        <table class="table table-hover align-middle">
            <caption class="visually-hidden">Tabla de bioquímicos registrados con sus datos principales y acciones disponibles.</caption>
            <thead class="table-success text-center">
                <tr>
                    <th>Nombre Completo</th>
                    <th>Carnet</th>
                    <th>Expedido</th>
                    <th>Teléfono</th>
                    <th>Email</th>
                    <th>Username</th>
                    <th>Estado</th>
                    <th style="width:170px">Acciones</th>
                </tr>
            </thead>

            <tbody>
                @if (Model.Bioquimicos.Count > 0)
                {
                    @foreach (var bioquimico in Model.Bioquimicos)
                    {
                        bool esActivo = bioquimico.Activo == 1;

                        <tr>
                            <td class="fw-semibold">@bioquimico.Nombres @bioquimico.ApellidoPaterno @bioquimico.ApellidoMaterno</td>
                            <td>@bioquimico.Ci</td>
                            <td class="text-center">@bioquimico.CiExtencion</td>
                            <td>@bioquimico.Telefono</td>
                            <td>@bioquimico.Email</td>
                            <td>@bioquimico.UserName</td>
                            <td>
                                @if (esActivo)
                                {
                                    <span class="badge bg-success">ACTIVO</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">DE BAJA</span>
                                }
                            </td>
                            <td>
                                <form method="post"
                                      asp-page="BioquimicoEdit"
                                      asp-page-handler="CargarBioquimicoParaEdicion"
                                      style="display:inline;">
                                    <input type="hidden" name="id" value="@bioquimico.IdUsuario" />
                                    <button type="submit" class="btn btn-warning btn-sm">
                                        Editar
                                    </button>
                                </form>

                                @if (esActivo)
                                {
                                    <button type="button"
                                            class="btn btn-danger btn-sm btnEliminar"
                                            data-id="@bioquimico.IdUsuario"
                                            data-nombre="@bioquimico.Nombres @bioquimico.ApellidoPaterno @bioquimico.ApellidoMaterno"
                                            data-bs-toggle="modal"
                                            data-bs-target="#modalEliminarBioquimico">
                                        Baja
                                    </button>
                                }
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="8" class="text-center py-4 text-muted">No se encontraron bioquímicos.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div class="modal fade"
     id="modalEliminarBioquimico"
     tabindex="-1"
     aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content shadow">
            <div class="modal-header bg-success text-white">
                <h5 class="modal-title">Confirmar baja</h5>
                <button type="button"
                        class="btn-close btn-close-white"
                        data-bs-dismiss="modal">
                </button>
            </div>

            <div class="modal-body">
                <p>¿Está seguro de que desea dar de baja a este bioquímico?</p>
                <p class="fw-bold" id="nombreBioquimicoEliminar"></p>
            </div>

            <div class="modal-footer">
                <button type="button"
                        class="btn btn-secondary"
                        data-bs-dismiss="modal">
                    Cancelar
                </button>

                <form method="post" asp-page-handler="EliminarBioquimicoLogicamente">
                    <input type="hidden" id="idBioquimicoEliminar" name="id" />
                    <input type="hidden" name="filtro" value="@Model.Estado.FiltroActual" />
                    <button type="submit" class="btn btn-danger">
                        Confirmar Baja
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const botonesEliminar = document.querySelectorAll(".btnEliminar");

            botonesEliminar.forEach(boton => {
                boton.addEventListener("click", function () {
                    const id = this.getAttribute("data-id");
                    const nombre = this.getAttribute("data-nombre");

                    document.getElementById("idBioquimicoEliminar").value = id;
                    document.getElementById("nombreBioquimicoEliminar").textContent = nombre;
                });
            });
        });
    </script>
}
