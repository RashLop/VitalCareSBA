@page
@model FrontendVitalCare.Pages.Bioquimico.BioquimicoCreateModel
@{
    ViewData["Title"] = "Nuevo Bioquimico - VitalCare";
}

<div class="container py-5 medicamento-form-page">
    <div class="row justify-content-center">
        <div class="col-lg-8 col-md-10">
            <div class="med-card shadow border-0" style="border-radius: 15px; overflow: hidden;">

                <div class="med-card-header text-center bg-success text-white py-3">
                    <h2 class="mb-0 fw-bold text-white">Nuevo Bioquimico</h2>
                    <p class="mb-0 small">Registra al bioquimico con los datos base del sistema</p>
                </div>

                <div class="med-card-body p-4">
                    <form method="post">
                        <div class="form-floating mb-3">
                            <input asp-for="Registro.Nombres" class="form-control med-input" placeholder="Nombres" />
                            <label class="ms-2">Nombres</label>
                            <span asp-validation-for="Registro.Nombres" class="text-danger"></span>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <div class="form-floating">
                                    <input asp-for="Registro.ApellidoPaterno" class="form-control med-input" placeholder="Primer apellido" />
                                    <label class="ms-2">Primer apellido</label>
                                    <span asp-validation-for="Registro.ApellidoPaterno" class="text-danger"></span>
                                </div>
                            </div>

                            <div class="col-md-6 mb-3">
                                <div class="form-floating">
                                    <input asp-for="Registro.ApellidoMaterno" class="form-control med-input" placeholder="Segundo apellido" />
                                    <label class="ms-2">Segundo apellido (opcional)</label>
                                    <span asp-validation-for="Registro.ApellidoMaterno" class="text-danger"></span>
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <div class="form-floating">
                                    <input asp-for="CiBase" class="form-control med-input" placeholder="Carnet de identidad" />
                                    <label class="ms-2">Carnet de identidad</label>
                                </div>
                            </div>

                            <div class="col-md-3 mb-3">
                                <div class="form-floating">
                                    <input asp-for="CiComplemento" class="form-control med-input" placeholder="Complemento" maxlength="2" />
                                    <label class="ms-2">Compl.</label>
                                </div>
                            </div>

                            <div class="col-md-3 mb-3">
                                <div class="form-floating">
                                    <select asp-for="Registro.CiExtencion" class="form-select med-input">
                                        <option value="">Seleccione</option>
                                        <option value="BE">Beni</option>
                                        <option value="CB">Cochabamba</option>
                                        <option value="CH">Chuquisaca</option>
                                        <option value="LP">La Paz</option>
                                        <option value="OR">Oruro</option>
                                        <option value="PD">Pando</option>
                                        <option value="PT">Potosi</option>
                                        <option value="SC">Santa Cruz</option>
                                        <option value="TJ">Tarija</option>
                                    </select>
                                    <label class="ms-2">Expedido</label>
                                    <span asp-validation-for="Registro.CiExtencion" class="text-danger"></span>
                                </div>
                            </div>
                        </div>

                        <div class="form-floating mb-3">
                            <input asp-for="Registro.Telefono" class="form-control med-input" placeholder="Telefono" />
                            <label class="ms-2">Telefono</label>
                            <span asp-validation-for="Registro.Telefono" class="text-danger"></span>
                        </div>

                        <div class="form-floating mb-3">
                            <input asp-for="Registro.Email" type="email" class="form-control med-input" placeholder="Correo electronico" />
                            <label class="ms-2">Correo electronico</label>
                            <span asp-validation-for="Registro.Email" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <small class="text-muted">
                                <i class="bi bi-info-circle me-1"></i> El usuario y contrasena se generaran automaticamente.
                            </small>
                        </div>

                        @if (!string.IsNullOrWhiteSpace(Model.Estado.Mensaje))
                        {
                            <div class="alert alert-success shadow-sm border-0">
                                @Model.Estado.Mensaje
                            </div>
                        }

                        @if (!string.IsNullOrWhiteSpace(Model.Estado.MensajeError))
                        {
                            <div class="alert alert-danger shadow-sm border-0">
                                @Model.Estado.MensajeError
                            </div>
                        }

                        <div class="d-flex justify-content-end gap-2 mt-4 border-top pt-3">
                            <a asp-page="Bioquimico" class="btn btn-secondary px-4">Cancelar</a>
                            <button type="submit" class="btn btn-success px-5 fw-bold shadow-sm" style="background-color: #198754;">
                                Guardar Registro
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
