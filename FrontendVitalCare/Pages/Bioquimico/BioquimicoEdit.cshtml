@page
@model FrontendVitalCare.Pages.Bioquimico.BioquimicoEditModel
@{
    ViewData["Title"] = "Actualizar Bioquímico - VitalCare";
}

<div class="container py-5 medicamento-form-page">
    <div class="row justify-content-center">
        <div class="col-lg-10 col-md-11">
            <div class="med-card shadow border-0" style="border-radius: 15px; overflow: hidden;">

                <div class="med-card-header text-center bg-success text-white py-3">
                    <h2 class="mb-0 fw-bold text-white">Actualizar Bioquímico</h2>
                    <p class="mb-0 small">Edita los datos personales y de acceso del profesional</p>
                </div>

                <div class="med-card-body p-4">
                    <form method="post" asp-page-handler="ActualizarBioquimico" id="bioquimicoEditForm">
                        <input type="hidden" asp-for="Input.IdUsuario" />
                        <input type="hidden" asp-for="Input.Role" />
                        <input type="hidden" asp-for="Input.MustChangePassword" />
                        <input type="hidden" asp-for="Input.UserName" />

                        <div class="form-floating mb-3">
                            <input asp-for="Input.Nombres" class="form-control med-input" placeholder="Nombres" maxlength="100" pattern="[A-Za-zÀ-ÖØ-öø-ÿ ]+" title="Solo se permiten letras y espacios." />
                            <label class="ms-2">Nombres</label>
                            <span asp-validation-for="Input.Nombres" class="text-danger"></span>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <div class="form-floating">
                                    <input asp-for="Input.ApellidoPaterno" class="form-control med-input" placeholder="Primer apellido" maxlength="100" pattern="[A-Za-zÀ-ÖØ-öø-ÿ ]+" title="Solo se permiten letras y espacios." />
                                    <label class="ms-2">Primer apellido</label>
                                    <span asp-validation-for="Input.ApellidoPaterno" class="text-danger"></span>
                                </div>
                            </div>

                            <div class="col-md-6 mb-3">
                                <div class="form-floating">
                                    <input asp-for="Input.ApellidoMaterno" class="form-control med-input" placeholder="Segundo apellido" maxlength="100" pattern="[A-Za-zÀ-ÖØ-öø-ÿ ]+" title="Solo se permiten letras y espacios." />
                                    <label class="ms-2">Segundo apellido (opcional)</label>
                                    <span asp-validation-for="Input.ApellidoMaterno" class="text-danger"></span>
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-7 mb-3">
                                <div class="form-floating">
                                    <input asp-for="CiBase" class="form-control med-input" placeholder="Carnet de identidad" />
                                    <label class="ms-2">Carnet de identidad</label>
                                </div>
                            </div>

                            <div class="col-md-2 mb-3">
                                <div class="form-floating">
                                    <input asp-for="CiComplemento" class="form-control med-input" placeholder="Complemento" maxlength="2" />
                                    <label class="ms-2">Compl.</label>
                                </div>
                            </div>

                            <div class="col-md-3 mb-3">
                                <div class="form-floating">
                                    <select asp-for="Input.CiExtencion" class="form-select med-input">
                                        <option value="">Seleccione</option>
                                        <option value="BE">Beni</option>
                                        <option value="CB">Cochabamba</option>
                                        <option value="CH">Chuquisaca</option>
                                        <option value="LP">La Paz</option>
                                        <option value="OR">Oruro</option>
                                        <option value="PD">Pando</option>
                                        <option value="PT">Potosí</option>
                                        <option value="SC">Santa Cruz</option>
                                        <option value="TJ">Tarija</option>
                                    </select>
                                    <label class="ms-2">Expedido</label>
                                    <span asp-validation-for="Input.CiExtencion" class="text-danger"></span>
                                </div>
                            </div>
                        </div>

                        <div class="form-floating mb-3">
                            <input asp-for="Input.Telefono" class="form-control med-input" placeholder="Teléfono" />
                            <label class="ms-2">Teléfono</label>
                            <span asp-validation-for="Input.Telefono" class="text-danger"></span>
                        </div>

                        <div class="form-floating mb-3">
                            <input asp-for="Input.Email" type="email" class="form-control med-input" placeholder="Correo electrónico" />
                            <label class="ms-2">Correo electrónico</label>
                            <span asp-validation-for="Input.Email" class="text-danger"></span>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-8">
                                <label class="form-label fw-bold small text-muted mb-1">Nombre de usuario (Sistema)</label>
                                <div class="form-control bg-light border-0 py-2">
                                    <span>@Model.Input.UserName</span>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="form-floating">
                                    <select asp-for="Input.Activo" class="form-select med-input">
                                        <option value="1">Activo</option>
                                        <option value="0">Inactivo</option>
                                    </select>
                                    <label class="ms-2">Estado</label>
                                </div>
                            </div>
                        </div>

                        @if (!string.IsNullOrWhiteSpace(Model.Estado.MensajeError))
                        {
                            <div class="alert alert-danger shadow-sm border-0">
                                <i class="bi bi-exclamation-triangle me-2"></i> @Model.Estado.MensajeError
                            </div>
                        }

                        <div class="d-flex justify-content-end gap-2 mt-4 border-top pt-3">
                            <a asp-page="Bioquimico" class="btn btn-secondary px-4">Cancelar</a>
                            <button type="submit" class="btn btn-success px-5 fw-bold shadow-sm" style="background-color: #198754;">
                                Actualizar Registro
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
