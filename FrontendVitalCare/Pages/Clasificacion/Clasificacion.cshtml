@page
@model FrontendVitalCare.Pages.Clasificacion.ClasificacionModel
@{
}

<div class="container mt-5">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-success">Clasificaciones</h2>

        <!-- Aquí se actualizó la clase a btn-main -->
        <a asp-page="ClasificacionCreate" class="btn-main">
            + Nueva Clasificación
        </a>
    </div>

    <!-- BUSCADOR -->
    <form method="get" class="mb-4">
        <div class="card-module p-3">
            <div class="input-group">
                <input type="text"
                       name="filtro"
                       class="form-control"
                       placeholder="Buscar..." />

                <button type="submit" class="btn btn-success btn-fixed">
                    Buscar
                </button>

                <a asp-page="Clasificacion" class="btn btn-secondary btn-fixed">
                    Limpiar
                </a>
            </div>
        </div>
    </form>

    <!-- MENSAJES -->
    @if (!string.IsNullOrEmpty(Model.Mensaje))
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
            @Model.Mensaje
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (!string.IsNullOrEmpty(Model.MensajeError))
    {
        <div class="alert alert-danger alert-dismissible fade show shadow-sm" role="alert">
            @Model.MensajeError
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- TABLA -->
    <div class="card-module">
        <table class="table table-hover align-middle">
            <thead class="table-success">
                <tr>
                    <th>Nombre</th>
                    <th>Origen</th>
                    <th>Descripción</th>
                    <th style="width:200px">Acciones</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var c in Model.Clasificaciones)
                {
                    <tr>
                        <td class="fw-semibold">@c.Nombre</td>
                        <td>@c.Origen</td>
                        <td>@c.Descripcion</td>
                        <td>
                            <a asp-page="ClasificacionUpdate" asp-route-id="@c.Id" class="btn btn-warning btn-sm">
                                Editar
                            </a>

                            <button type="button"
                                    class="btn btn-danger btn-sm btnEliminar"
                                    data-id="@c.Id"
                                    data-nombre="@c.Nombre"
                                    data-bs-toggle="modal"
                                    data-bs-target="#modalEliminar">
                                Eliminar
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

</div>

<!-- MODAL ELIMINAR -->
<div class="modal fade" id="modalEliminar" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content shadow">

            <div class="modal-header bg-success text-white">
                <h5 class="modal-title">Confirmar eliminación</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">
                <p>¿Seguro que deseas eliminar?</p>
                <p id="nombreEliminar" class="fw-bold"></p>
            </div>

            <div class="modal-footer">
                <button class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                <form method="post" asp-page-handler="Eliminar" style="display:inline;">
                    <input type="hidden" id="idEliminar" name="id" />
                    <button type="submit" class="btn btn-danger">Eliminar</button>
                </form>
            </div>

        </div>
    </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        const botonesEliminar = document.querySelectorAll(".btnEliminar");

        botonesEliminar.forEach(boton => {
            boton.addEventListener("click", function () {
                const id = this.getAttribute("data-id");
                const nombre = this.getAttribute("data-nombre");

                document.getElementById("idEliminar").value = id;
                document.getElementById("nombreEliminar").textContent = nombre;
            });
        });
    });
</script>