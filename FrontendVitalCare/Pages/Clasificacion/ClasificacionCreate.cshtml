@page
@model FrontendVitalCare.Pages.ClasificacionCreateModel
{

}

<div class="container py-5 medicamento-form-page">
    <div class="row justify-content-center">
        <div class="col-lg-6 col-md-8">

            <div class="med-card shadow border-0" style="border-radius: 15px; overflow: hidden;">

                <div class="med-card-header text-center bg-success text-white py-3">
                    <h2 class="mb-0 fw-bold text-white">Nueva Clasificación</h2>
                    <p class="mb-0 small">Completa los datos</p>
                </div>

                <div class="med-card-body p-4">

                    <!-- FORM SIN POST -->
                    <form onsubmit="crear(event)">

                        <div class="form-floating mb-3">
                            <input id="nombre" class="form-control" placeholder="Nombre" required />
                            <label>Nombre de Clasificación</label>
                        </div>

                        <div class="form-floating mb-3">
                            <select id="origen" class="form-select" required>
                                <option value="" disabled selected>Seleccione</option>
                                <option value="Natural">Natural</option>
                                <option value="Sintético">Sintético</option>
                                <option value="Semisintético">Semisintético</option>
                            </select>
                            <label>Origen</label>
                        </div>

                        <div class="form-floating mb-3">
                            <textarea id="descripcion" class="form-control"
                                      style="height: 120px" required></textarea>
                            <label>Descripción</label>
                        </div>

                        <!-- MENSAJES -->
                        <div id="error" class="alert alert-danger d-none"></div>
                        <div id="ok" class="alert alert-success d-none"></div>

                        <div class="d-flex justify-content-end gap-2 mt-4 pt-3 border-top">
                            <a href="/Clasificacion/Clasificacion" class="btn btn-secondary">Volver</a>

                            <button type="submit" class="btn btn-success fw-bold">
                                Guardar
                            </button>
                        </div>

                    </form>

                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
<script>
    const API = "http://localhost:5080/api/clasificaciones";

    async function crear(event) {
        event.preventDefault(); // 🚫 evita POST clásico

        const data = {
            nombre: document.getElementById("nombre").value,
            origen: document.getElementById("origen").value,
            descripcion: document.getElementById("descripcion").value,
            idUsuario: 1 // ⚠️ luego puedes hacerlo dinámico
        };

        const res = await fetch(API, {
            method: "POST",
            headers: {
                "Content-Type": "application/json"
            },
            body: JSON.stringify(data)
        });

        if (res.ok) {
            mostrarOk("Clasificación creada");

            // 🔁 opcional: redirigir
            setTimeout(() => {
                        window.location.href = "/Clasificacion/Clasificacion";
            }, 1000);

        } else {
            mostrarError("Error al crear clasificación");
        }
    }

    function mostrarOk(msg) {
        const div = document.getElementById("ok");
        div.innerText = msg;
        div.classList.remove("d-none");
    }

    function mostrarError(msg) {
        const div = document.getElementById("error");
        div.innerText = msg;
        div.classList.remove("d-none");
    }
</script>
}