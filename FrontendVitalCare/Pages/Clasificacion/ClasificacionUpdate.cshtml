@page
@model FrontendVitalCare.Pages.ClasificacionUpdateModel
{

}

<div class="container py-5">
    <div class="col-lg-6 mx-auto">

        <h2 class="text-success mb-4">Actualizar Clasificación</h2>

        <form onsubmit="actualizar(event)">

            <input type="hidden" id="id" />

            <div class="mb-3">
                <input id="nombre" class="form-control" placeholder="Nombre" required />
            </div>

            <div class="mb-3">
                <select id="origen" class="form-select" required>
                    <option value="Natural">Natural</option>
                    <option value="Sintético">Sintético</option>
                    <option value="Semisintético">Semisintético</option>
                </select>
            </div>

            <div class="mb-3">
                <textarea id="descripcion" class="form-control" required></textarea>
            </div>

            <div id="error" class="alert alert-danger d-none"></div>
            <div id="ok" class="alert alert-success d-none"></div>

            <button class="btn btn-success">Actualizar</button>
            <a href="/Clasificacion/Clasificacion" class="btn btn-secondary">Volver</a>

        </form>

    </div>
</div>

@section Scripts {
    <script>
        const API = "http://localhost:5080/api/clasificaciones";

        // 🔹 obtener ID desde URL
        const params = new URLSearchParams(window.location.search);
        const id = params.get("id");

        // 🔹 cargar datos al iniciar
        async function cargar() {
            const res = await fetch(`${API}/${id}`);
            const data = await res.json();

            document.getElementById("id").value = data.id;
            document.getElementById("nombre").value = data.nombre;
            document.getElementById("origen").value = data.origen;
            document.getElementById("descripcion").value = data.descripcion;
        }

        // 🔹 actualizar
        async function actualizar(event) {
            event.preventDefault();

            const data = {
                id: id,
                nombre: document.getElementById("nombre").value,
                origen: document.getElementById("origen").value,
                descripcion: document.getElementById("descripcion").value,
                idUsuario: 1
            };

            const res = await fetch(`${API}/${id}`, {
                method: "PUT",
                headers: {
                    "Content-Type": "application/json"
                },
                body: JSON.stringify(data)
            });

            if (res.ok) {
                mostrarOk("Actualizado correctamente");

                setTimeout(() => {
                    window.location.href = "/Clasificacion/Clasificacion";
                }, 1000);
            } else {
                const err = await res.json();
                mostrarError(err.mensaje || "Error al actualizar");
            }
        }

        function mostrarOk(msg) {
            const div = document.getElementById("ok");
            div.innerText = msg;
            div.classList.remove("d-none");
        }

        function mostrarError(msg) {
            const div = document.getElementById("error");
            div.innerText = msg;
            div.classList.remove("d-none");
        }

        // 🚀 auto cargar
        cargar();
    </script>
}
