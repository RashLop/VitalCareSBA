@page
@model FrontendVitalCare.Pages.Clasificacion.ClasificacionUpdateModel

<div class="container py-5 medicamento-form-page">
    <div class="row justify-content-center">
        <div class="col-lg-6 col-md-8">
            <div class="med-card shadow border-0" style="border-radius: 15px; overflow: hidden;">
                <div class="med-card-header text-center bg-success text-white py-3">
                    <h2 class="mb-0 fw-bold text-white">Actualizar Clasificación</h2>
                    <p class="mb-0 small">Modifica los datos de la clasificación</p>
                </div>

                <div class="med-card-body p-4">
                    @if (Model.Clasificacion != null)
                    {
                        <form method="post" asp-page-handler="ActualizarClasificacion">
                            <input type="hidden" asp-for="Id" />

                            <div class="form-floating mb-3">
                                <input asp-for="Nombre" class="form-control" placeholder="Nombre" required />
                                <label class="ms-2">Nombre de Clasificación</label>
                            </div>

                            <div class="form-floating mb-3">
                                <select asp-for="Origen" class="form-select" required>
                                    <option value="">Seleccione</option>
                                    <option value="Natural" selected="@(Model.Origen == "Natural")">Natural</option>
                                    <option value="Sintético" selected="@(Model.Origen == "Sintético")">Sintético</option>
                                    <option value="Semisintético" selected="@(Model.Origen == "Semisintético")">Semisintético</option>
                                </select>
                                <label class="ms-2">Origen</label>
                            </div>

                            <div class="form-floating mb-3">
                                <textarea asp-for="Descripcion" class="form-control"
                                          style="height: 120px" required></textarea>
                                <label class="ms-2">Descripción</label>
                            </div>

                            @if (!string.IsNullOrEmpty(Model.MensajeError))
                            {
                                <div class="alert alert-danger">@Model.MensajeError</div>
                            }

                            <div class="d-flex justify-content-end gap-2 mt-4 pt-3 border-top">
                                <a asp-page="Clasificacion" class="btn btn-secondary">Volver</a>
                                <button type="submit" class="btn btn-success px-5 fw-bold shadow-sm">Actualizar</button>
                            </div>
                        </form>
                    }
                    else
                    {
                        <div class="alert alert-warning">
                            No se encontraron datos de la clasificación.
                        </div>
                        <div class="d-flex justify-content-end gap-2 mt-4 pt-3 border-top">
                            <a asp-page="Clasificacion" class="btn btn-secondary">Volver</a>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

        // 🔹 cargar datos
        async function cargar() {
            const res = await ClasificacionAdapter.obtenerPorId(id);

            if (!res.ok) {
                mostrarError("Error al cargar datos");
                return;
            }

            const data = res.data;

            document.getElementById("id").value = data.id;
            document.getElementById("nombre").value = data.nombre;
            document.getElementById("origen").value = data.origen;
            document.getElementById("descripcion").value = data.descripcion;
        }

        // 🔹 actualizar
        async function actualizar(event) {
            event.preventDefault();

            const data = {
                nombre: document.getElementById("nombre").value,
                origen: document.getElementById("origen").value,
                descripcion: document.getElementById("descripcion").value,
                idUsuario: 1
            };

            const res = await ClasificacionAdapter.actualizar(id, data);

            if (res.ok) {
                mostrarOk("Actualizado correctamente");

                setTimeout(() => {
                    window.location.href = "/Clasificacion/Clasificacion";
                }, 1000);
            } else {
                mostrarError(res.data?.mensaje || "Error al actualizar");
            }
        }

        function mostrarOk(msg) {
            const div = document.getElementById("ok");
            div.innerText = msg;
            div.classList.remove("d-none");
        }

        function mostrarError(msg) {
            const div = document.getElementById("error");
            div.innerText = msg;
            div.classList.remove("d-none");
        }

        // 🚀 auto cargar
        cargar();

    </script>
}