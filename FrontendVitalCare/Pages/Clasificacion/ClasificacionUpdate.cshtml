@page
@model ProyectoArqSoft.Pages.ClasificacionUpdateModel

<div class="container py-5 medicamento-form-page">
    <div class="row justify-content-center">
        <div class="col-lg-6 col-md-8">
            <div class="med-card shadow border-0" style="border-radius: 15px; overflow: hidden;">
                <div class="med-card-header text-center bg-success text-white py-3">
                    <h2 class="mb-0 fw-bold text-white">Actualizar Clasificación</h2>
                    <p class="mb-0 small">Modifica los datos de la clasificación seleccionada</p>
                </div>

                <div class="med-card-body p-4">
                    <form method="post" asp-page-handler="ActualizarClasificacion">
                        <input type="hidden" asp-for="IdClasificacion" />

                        <div class="form-floating mb-3">
                            <input asp-for="Nombre" class="form-control med-input" placeholder="Nombre" required />
                            <label class="ms-2">Nombre de Clasificación</label>
                        </div>

                        <div class="form-floating mb-3">
                            <select asp-for="Origen" class="form-select med-input" required>
                                <option value="Natural">Natural</option>
                                <option value="Sintético">Sintético</option>
                                <option value="Semisintético">Semisintético</option>
                            </select>
                            <label class="ms-2">Origen</label>
                        </div>

                        <div class="form-floating mb-3">
                            <textarea asp-for="Descripcion" class="form-control med-input" placeholder="Descripción" style="height: 120px" required></textarea>
                            <label class="ms-2">Descripción</label>
                        </div>

                        @if (!string.IsNullOrEmpty(Model.Estado.MensajeError))
                        {
                            <div class="alert alert-danger border-0 shadow-sm">@Model.Estado.MensajeError</div>
                        }

                        <div class="d-flex justify-content-end gap-2 mt-4 pt-3 border-top">
                            <a asp-page="Clasificacion" class="btn btn-secondary px-4">Volver</a>
                            <button type="submit" class="btn btn-success px-5 fw-bold shadow-sm" style="background-color: #198754;">Actualizar</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
