@page
@model IndexModel
@{
    ViewData["Title"] = "Inicio";
}

<div class="main-wrapper">

    <section class="slider d-flex align-items-center">
        <div class="container">
            <div class="row align-items-center">

                <div class="col-md-7 text-white">

                    @if (string.IsNullOrWhiteSpace(Model.Usuario))
                    {
                        <span class="subhead text-uppercase">Bienvenido a</span>

                        <h1 class="display-4 fw-bold mb-4">
                            Farmacia VitalCare
                        </h1>

                        <p class="mb-4">
                            Sistema profesional para la gestión eficiente de
                            inventario, ventas y personal farmacéutico.
                        </p>

                        <a asp-page="/Auth/Login" class="btn-main me-3">
                            Iniciar Sesión
                        </a>
                    }
                    else
                    {
                        <span class="subhead text-uppercase">Panel Administrativo</span>

                        <h1 class="display-5 fw-bold mb-4">
                            Bienvenido, <span class="text-accent">@Model.Usuario</span>
                        </h1>

                        <p class="mb-4">
                            Tu sesión está activa como <strong>@Model.Role</strong>.
                            Usa el menú superior para acceder a los módulos habilitados.
                        </p>

                        <a asp-page="/Cliente/Cliente" class="btn-main me-3">
                            Ir a Clientes
                        </a>
                    }
                </div>

                <div class="col-md-5 text-center">
                    <img src="~/images/vitalcare.png"
                         alt="Logotipo de VitalCare"
                         class="img-fluid"
                         style="max-height:250px;" />
                </div>

            </div>
        </div>
    </section>

    <section class="section bg-light text-center">
        <div class="container">
            <h2 class="mb-3">Comprometidos con la Salud</h2>
            <p class="text-muted mb-5">
                VitalCare proporciona herramientas modernas para optimizar
                los procesos farmacéuticos y garantizar una atención segura.
            </p>

            <div class="row">
                <div class="col-md-4">
                    <h4 class="text-success">
                        <i class="bi bi-shield-lock-fill"></i> Seguridad
                    </h4>
                    <p>Control de accesos y protección de datos.</p>
                </div>
                <div class="col-md-4">
                    <h4 class="text-success">
                        <i class="bi bi-lightning-charge-fill"></i> Eficiencia
                    </h4>
                    <p>Gestión rápida y ordenada de inventario.</p>
                </div>
                <div class="col-md-4">
                    <h4 class="text-success">
                        <i class="bi bi-heart-pulse-fill"></i> Confianza
                    </h4>
                    <p>Registro transparente de cada transacción.</p>
                </div>
            </div>
        </div>
    </section>

    @if (!string.IsNullOrWhiteSpace(Model.Usuario))
    {
        <section class="section text-center">
            <div class="container">
                <h2 class="mb-5">Módulos Disponibles</h2>

                <div class="row justify-content-center">
                    <div class="col-lg-4 mb-4">
                        <div class="card-module">
                            <h3><i class="bi bi-people-fill"></i> Clientes</h3>
                            <p>Consulta y administra la información de clientes registrados.</p>
                            <a asp-page="/Cliente/Cliente">Entrar</a>
                        </div>
                    </div>

                    <div class="col-lg-4 mb-4">
                        <div class="card-module">
                            <h3><i class="bi bi-tags-fill"></i> Clasificaciones</h3>
                            <p>Gestiona las clasificaciones disponibles en el frontend actual.</p>
                            <a asp-page="/Clasificacion/Clasificacion">Entrar</a>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    }

</div>
