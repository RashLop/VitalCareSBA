@page
@model FrontendVitalCare.Pages.Medicamento.CrearMedicamento

<div class="container py-5 medicamento-form-page">
    <div class="row justify-content-center">
        <div class="col-lg-6 col-md-8">
            <div class="med-card shadow border-0" style="border-radius: 15px; overflow: hidden;">
                
                <!-- Header -->
                <div class="med-card-header text-center bg-success text-white py-3">
                    <h2 class="mb-0 fw-bold text-white">Nuevo Medicamento</h2>
                    <p class="mb-0 small">Completa los datos para registrar un medicamento</p>
                </div>

                <!-- Body -->
                <div class="med-card-body p-4">
                    <form method="post" asp-page-handler="CrearMedicamento">

                        <!-- Nombre -->
                        <div class="form-floating mb-3">
                            <input asp-for="Medicamento.Nombre" class="form-control med-input" placeholder="Nombre" required />
                            <label class="ms-2">Nombre del Medicamento</label>
                        </div>

                        <!-- Presentación -->
                        <div class="form-floating mb-3">
                            <select asp-for="Medicamento.Presentacion" class="form-select med-input" required>
                                <option value="" selected disabled>Seleccione una presentación</option>
                                <option value="Cápsulas">Cápsulas</option>
                                <option value="Crema">Crema</option>
                                <option value="Gotas">Gotas</option>
                                <option value="Inyectable">Inyectable</option>
                                <option value="Jarabe">Jarabe</option>
                                <option value="Polvo">Polvo</option>
                                <option value="Pomada">Pomada</option>
                                <option value="Suspensión">Suspensión</option>
                                <option value="Tabletas">Tabletas</option>
                            </select>
                            <label class="ms-2">Presentación</label>
                        </div>

                        <!-- Clasificación -->
                        <div class="form-floating mb-3">
                            <select asp-for="Medicamento.Clasificacion" class="form-select med-input" required>
                                <option value="" selected disabled>Seleccione una clasificación</option>

                            </select>
                            <label class="ms-2">Clasificación</label>
                        </div>

                        <!-- Concentración -->
                        <div class="form-floating mb-1">
                            <input asp-for="Medicamento.Concentracion" class="form-control med-input" placeholder="Ej: 250 mg/5ml" required />
                            <label class="ms-2">Concentración</label>
                        </div>
                        <div class="form-text mb-3 ms-2">Ej: 500 mg, 250 mg/5ml o 0.9 %</div>

                        <!-- Precio y Stock -->
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label d-block small fw-bold">Precio</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light text-success fw-bold">Bs.</span>
                                    <input asp-for="Medicamento.Precio" type="number" step="0.01" class="form-control med-input" placeholder="0.00" required />
                                </div>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label d-block small fw-bold">Stock Inicial</label>
                                <input asp-for="Medicamento.Stock" type="number" min="0" class="form-control med-input" placeholder="0" required />
                            </div>
                        </div>

                        <!-- Mensajes de error -->
                        @if (!string.IsNullOrWhiteSpace(Model.MensajeError))
                        {
                            <div class="alert alert-danger border-0 shadow-sm">@Model.MensajeError</div>
                        }

                        <!-- Botones -->
                        <div class="d-flex justify-content-end gap-2 mt-4 pt-3 border-top">
                            <a asp-page="Medicamento" class="btn btn-secondary px-4">Volver</a>
                            <button type="submit" class="btn btn-success px-5 fw-bold shadow-sm">Guardar</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>