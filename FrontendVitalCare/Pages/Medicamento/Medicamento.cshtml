@page
@model FrontendVitalCare.Pages.Medicamento.MedicamentoPageModel
@{
    ViewData["Title"] = "Medicamentos";
}

<div class="container mt-5">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-success">Medicamentos en Stock</h2>
        <a asp-page="/Medicamento/CrearMedicamento" class="btn-main">+ Nuevo Medicamento</a>

    </div>

    <!-- BUSCADOR -->
    <form method="get" class="mb-4">
        <div class="card-module p-3">
            <div class="input-group">
                <input type="text" name="filtro" class="form-control" placeholder="Buscar..." />
                <button type="submit" class="btn btn-success btn-fixed">Buscar</button>
                <a asp-page="Medicamento" class="btn btn-secondary btn-fixed">Limpiar</a>
            </div>
        </div>
    </form>

    <!-- MENSAJES -->
    @if (!string.IsNullOrEmpty(Model.Mensaje))
    {
        <div class="alert alert-success shadow-sm">@Model.Mensaje</div>
    }
    @if (!string.IsNullOrEmpty(Model.MensajeError))
    {
        <div class="alert alert-danger shadow-sm">@Model.MensajeError</div>
    }

    <!-- TABLA -->
    <div class="card-module">
        <table class="table table-hover align-middle">
            <thead class="table-success">
                <tr>
                    <th>Nombre</th>
                    <th>Presentación</th>
                    <th>Clasificación</th>
                    <th>Precio (Bs)</th>
                    <th style="width:170px">Acciones</th> <!-- Eliminamos Stock -->
                </tr>
            </thead>
            <tbody>
                @foreach (var m in Model.Medicamentos)
                {
                    <tr>
                        <td class="fw-semibold">@m.Nombre</td>
                        <td>@m.Presentacion</td>
                        <td><span class="badge bg-info text-dark">@m.Clasificacion</span></td>
                        <td class="text-success fw-bold">@m.Precio</td>
                        <td>
                            <a asp-page="MedicamentoUpdate" asp-route-id="@m.Id" class="btn btn-warning btn-sm">Editar</a>

                            <button type="button" class="btn btn-danger btn-sm btnEliminar"
                                    data-id="@m.Id" data-nombre="@m.Nombre"
                                    data-bs-toggle="modal" data-bs-target="#modalEliminarMedicamento">
                                Eliminar
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

</div>

<!-- MODAL ELIMINACION -->
<div class="modal fade" id="modalEliminarMedicamento" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content shadow">
            <div class="modal-header bg-success text-white">
                <h5 class="modal-title">Confirmar eliminación</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>¿Está seguro de que desea eliminar este medicamento?</p>
                <p class="fw-bold" id="nombreMedicamentoEliminar"></p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                <form method="post" asp-page-handler="Eliminar">
                    <input type="hidden" id="idMedicamentoEliminar" name="id" />
                    <button type="submit" class="btn btn-danger">Eliminar</button>
                </form>
            </div>
        </div>
    </div>
</div>

<script>
document.addEventListener("DOMContentLoaded", function () {
    const botonesEliminar = document.querySelectorAll(".btnEliminar");

    botonesEliminar.forEach(boton => {
        boton.addEventListener("click", function () {
            const id = this.getAttribute("data-id");
            const nombre = this.getAttribute("data-nombre");
            document.getElementById("idMedicamentoEliminar").value = id;
            document.getElementById("nombreMedicamentoEliminar").textContent = nombre;
        });
    });
});
</script>