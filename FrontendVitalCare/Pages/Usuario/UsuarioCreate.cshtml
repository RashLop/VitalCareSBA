@page
@model FrontendVitalCare.Pages.Usuario.UsuarioCreateModel
@{
    ViewData["Title"] = "Nuevo Registro - VitalCare";
}

<div class="container py-5 mt-4">
    <div class="row justify-content-center">
        <div class="col-lg-8">

            <div class="med-card shadow border-0">
                <div class="med-card-header text-center bg-success text-white py-3">
                    <h2 class="mb-0 fw-bold text-white">
                        Registro de Usuario
                    </h2>
                    <p class="mb-0 small">Las credenciales se generarán y enviarán automáticamente</p>
                </div>

                <div class="med-card-body p-4">
                    <form method="post" asp-page-handler="CrearUsuario" class="row g-3">

                        <div class="col-md-12 form-floating mb-1">
                            <input asp-for="Input.Nombres" class="form-control med-input" placeholder="Nombre" required maxlength="100" pattern="[A-Za-zÀ-ÖØ-öø-ÿ ]+" title="Solo se permiten letras y espacios." />
                            <label class="ms-2">Nombres</label>
                        </div>

                        <div class="col-md-6 form-floating">
                            <input asp-for="Input.ApellidoPaterno" class="form-control med-input" placeholder="Primer Apellido" required maxlength="100" pattern="[A-Za-zÀ-ÖØ-öø-ÿ ]+" title="Solo se permiten letras y espacios." />
                            <label class="ms-2">Primer Apellido</label>
                        </div>

                        <div class="col-md-6 form-floating">
                            <input asp-for="Input.ApellidoMaterno" class="form-control med-input" placeholder="Segundo Apellido" maxlength="100" pattern="[A-Za-zÀ-ÖØ-öø-ÿ ]+" title="Solo se permiten letras y espacios." />
                            <label class="ms-2">Segundo Apellido</label>
                        </div>

                        <div class="col-md-4 form-floating">
                            <input asp-for="CiBase" class="form-control med-input" placeholder="CI" required maxlength="8" />
                            <label class="ms-2">C.I.</label>
                        </div>

                        <div class="col-md-4 form-floating">
                            <input asp-for="CiComplemento" class="form-control med-input" placeholder="Complemento" maxlength="2" />
                            <label class="ms-2">Complemento (opcional)</label>
                        </div>

                        <div class="col-md-4 form-floating">
                            <select asp-for="Input.CiExtencion" class="form-select" required>
                                <option value="BE">Beni</option>
                                <option value="CB">Cochabamba</option>
                                <option value="CH">Chuquisaca</option>
                                <option value="LP">La Paz</option>
                                <option value="OR">Oruro</option>
                                <option value="PD">Pando</option>
                                <option value="PT">Potosí</option>
                                <option value="SC">Santa Cruz</option>
                                <option value="TJ">Tarija</option>
                            </select>
                            <label asp-for="Input.CiExtencion">Expedido en</label>
                        </div>

                        <div class="col-md-4 form-floating">
                            <input asp-for="Input.Telefono" class="form-control med-input" placeholder="Telf" required maxlength="8" />
                            <label class="ms-2">Teléfono</label>
                        </div>

                        <div class="col-md-8 form-floating">
                            <input asp-for="Input.Email" type="email" class="form-control med-input" placeholder="Email" required />
                            <label class="ms-2">Correo Electrónico oficial</label>
                        </div>

                        <div class="col-md-4 form-floating">
                            <select asp-for="Input.Role" class="form-select med-input">
                                <option value="Bioquimico">Bioquímico (Personal)</option>
                                <option value="Admin">Administrador (Gestión)</option>
                            </select>
                            <label class="ms-2">Tipo de acceso</label>
                        </div>

                        <div id="errorModal" class="modal-backdrop @(string.IsNullOrEmpty(Model.Estado.MensajeError) ? string.Empty : "open")">
                            <div class="modal-content">
                                <h2>Error de registro</h2>
                                <p>@Model.Estado.MensajeError</p>
                                <div class="modal-actions">
                                    <button type="button" id="closeModal">Cerrar</button>
                                </div>
                            </div>
                        </div>

                        <div class="d-flex justify-content-end gap-2 mt-4 pt-3 border-top">
                            <a asp-page="Usuario" class="btn btn-secondary px-4">Cancelar</a>
                            <button type="submit" class="btn btn-success px-5 fw-bold shadow-sm" style="background-color: #198754;">
                                Generar y Registrar
                            </button>
                        </div>

                    </form>
                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const errorModal = document.getElementById("errorModal");
            const closeModal = document.getElementById("closeModal");

            if (errorModal && closeModal) {
                closeModal.addEventListener("click", function () {
                    errorModal.classList.remove("open");
                });

                errorModal.addEventListener("click", function (event) {
                    if (event.target === errorModal) {
                        errorModal.classList.remove("open");
                    }
                });
            }
        });
    </script>
}
