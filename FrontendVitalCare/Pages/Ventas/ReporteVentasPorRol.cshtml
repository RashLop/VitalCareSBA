@page
@model FrontendVitalCare.Pages.Ventas.ReporteVentasPorRolModel
@{
    ViewData["Title"] = "Reporte por Rol";
}

<div class="container mt-5">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">
        <div>
            <h2 class="fw-bold text-success mb-1">Reporte de Ventas por Rol</h2>
            <p class="text-muted mb-0">
                Periodo actual:
                <span class="fw-semibold">
                    @(string.IsNullOrWhiteSpace(Model.Reporte.Desde) ? "Sin rango disponible" : $"{Model.Reporte.Desde} - {Model.Reporte.Hasta}")
                </span>
            </p>
        </div>

        <div class="d-flex gap-2">
            <a asp-page="Venta" class="btn btn-secondary">Volver a Ventas</a>
            <a asp-page-handler="DescargarExcel" class="btn btn-outline-success">
                <i class="bi bi-file-earmark-excel me-1"></i> Descargar Excel
            </a>
            <a asp-page-handler="DescargarPdf" class="btn btn-success">
                <i class="bi bi-file-earmark-pdf me-1"></i> Descargar PDF
            </a>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.Estado.MensajeError))
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @Model.Estado.MensajeError
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card-module p-4">
        @if (Model.TieneDatos)
        {
            <div class="row g-3 mb-4">
                <div class="col-md-4">
                    <div class="summary-card h-100">
                        <span class="summary-label">Total de ventas</span>
                        <strong class="summary-value">@Model.TotalVentas</strong>
                        <small class="summary-help">Ventas activas del periodo seleccionado</small>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="summary-card h-100">
                        <span class="summary-label">Total recaudado</span>
                        <strong class="summary-value">Bs. @Model.TotalRecaudado.ToString("N2")</strong>
                        <small class="summary-help">Suma de todas las ventas activas</small>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="summary-card h-100">
                        <span class="summary-label">Rol con mayor recaudación</span>
                        <strong class="summary-value">@(Model.RolConMasRecaudacion?.Rol ?? "Sin datos")</strong>
                        <small class="summary-help">
                            @(Model.RolConMasRecaudacion == null ? "Sin información disponible" : $"Bs. {Model.RolConMasRecaudacion.TotalRecaudado:N2}")
                        </small>
                    </div>
                </div>
            </div>

            <div class="report-panel mb-4">
                <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
                    <div>
                        <h5 class="mb-1 text-success fw-bold">Visualización Estadística</h5>
                        <p class="text-muted mb-0">Comparación del total recaudado por rol durante el mes actual.</p>
                    </div>
                    <span class="badge bg-success-subtle text-success-emphasis px-3 py-2">
                        Top en ventas: @(Model.RolConMasVentas?.Rol ?? "Sin datos")
                    </span>
                </div>

                <div class="chart-stack">
                    @foreach (var item in Model.Reporte.Data.OrderByDescending(x => x.TotalRecaudado))
                    {
                        var porcentaje = Model.MaximoRecaudado <= 0
                            ? 0
                            : Math.Round((item.TotalRecaudado / Model.MaximoRecaudado) * 100m, 2);

                        <div class="chart-row">
                            <div class="chart-meta">
                                <span class="chart-role">@item.Rol</span>
                                <span class="chart-caption">@item.CantidadVentas venta(s)</span>
                            </div>

                            <div class="chart-bar-shell">
                                <div class="chart-bar-fill" style="width:@($"{porcentaje}%")"></div>
                            </div>

                            <div class="chart-value">
                                Bs. @item.TotalRecaudado.ToString("N2")
                            </div>
                        </div>
                    }
                </div>
            </div>

            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-success">
                        <tr>
                            <th>Rol</th>
                            <th class="text-center">Cantidad de Ventas</th>
                            <th class="text-end">Total Recaudado (Bs.)</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Reporte.Data)
                        {
                            <tr>
                                <td class="fw-semibold">@item.Rol</td>
                                <td class="text-center">@item.CantidadVentas</td>
                                <td class="text-end text-success fw-bold">@item.TotalRecaudado.ToString("N2")</td>
                            </tr>
                        }
                    </tbody>
                    <tfoot>
                        <tr class="table-light">
                            <th>Total</th>
                            <th class="text-center">@Model.Reporte.Data.Sum(x => x.CantidadVentas)</th>
                            <th class="text-end text-success">@Model.Reporte.Data.Sum(x => x.TotalRecaudado).ToString("N2")</th>
                        </tr>
                    </tfoot>
                </table>
            </div>
        }
        else
        {
            <div class="text-center py-5">
                <h5 class="text-muted">No hay ventas registradas para el periodo actual.</h5>
                <p class="text-secondary mb-0">Cuando existan ventas del mes, el resumen aparecerá aquí.</p>
            </div>
        }
    </div>
</div>

<style>
    .summary-card {
        background: linear-gradient(145deg, #f6fffb 0%, #eef7f4 100%);
        border: 1px solid rgba(25, 135, 84, 0.12);
        border-radius: 18px;
        padding: 1.1rem 1.2rem;
        box-shadow: 0 12px 28px rgba(15, 45, 32, 0.08);
        display: flex;
        flex-direction: column;
        gap: 0.35rem;
    }

    .summary-label {
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 0.04em;
        color: #4a6a5d;
    }

    .summary-value {
        font-size: 1.55rem;
        color: #157347;
        line-height: 1.1;
    }

    .summary-help {
        color: #6c757d;
    }

    .report-panel {
        background: linear-gradient(180deg, #ffffff 0%, #f6fbf8 100%);
        border: 1px solid rgba(25, 135, 84, 0.12);
        border-radius: 20px;
        padding: 1.4rem;
    }

    .chart-stack {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .chart-row {
        display: grid;
        grid-template-columns: minmax(140px, 180px) 1fr minmax(110px, 140px);
        gap: 1rem;
        align-items: center;
    }

    .chart-meta {
        display: flex;
        flex-direction: column;
        gap: 0.15rem;
    }

    .chart-role {
        font-weight: 700;
        color: #174d36;
    }

    .chart-caption {
        font-size: 0.85rem;
        color: #71817a;
    }

    .chart-bar-shell {
        width: 100%;
        height: 18px;
        border-radius: 999px;
        overflow: hidden;
        background: #dbe9e2;
        box-shadow: inset 0 1px 2px rgba(0, 0, 0, 0.08);
    }

    .chart-bar-fill {
        height: 100%;
        border-radius: 999px;
        background: linear-gradient(90deg, #198754 0%, #32b66a 100%);
        box-shadow: 0 6px 12px rgba(25, 135, 84, 0.22);
    }

    .chart-value {
        text-align: right;
        font-weight: 700;
        color: #0f5132;
    }

    @@media (max-width: 768px) {
        .chart-row {
            grid-template-columns: 1fr;
            gap: 0.5rem;
        }

        .chart-value {
            text-align: left;
        }
    }
</style>
